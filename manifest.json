{
  "manifest_version": 3,
  "name": "YouDub",
  "version": "1.0",
  "icons": {
    "16": "images/image3.png",
    "48": "images/image3.png",
    "128": "images/image3.png"
  },
  "description": "Real-time English dubbing for Indic videos on YouTube",

  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "scripting",
    "offscreen"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

"content_security_policy": {
  "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
},

  "action": {
    "default_icon": {
      "16": "images/image3.png",
      "32": "images/image3.png"
    },
    "default_popup": "popup.html",
    "default_title": "YouDub"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
  {
    "resources": [
      "offscreen.html",
      "transformers.min.js",
      "ort-wasm-simd-threaded.jsep.mjs",
      "ort-wasm-simd-threaded.wasm",
      "ort-wasm-simd-threaded.jsep.wasm",
      "image3.png",
      "audio-processor.js"
    ],
    "matches": ["<all_urls>"]
  }
  
]
}